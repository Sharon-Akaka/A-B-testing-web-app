# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Video URLs — host your videos on Vimeo, cloud storage, etc.
# Defaults to /videos/version-a.mp4 and /videos/version-b.mp4 in the public folder
NEXT_PUBLIC_VIDEO_A_URL=https://your-cdn.com/version-a.mp4
NEXT_PUBLIC_VIDEO_B_URL=https://your-cdn.com/version-b.mp4

# Dashboard password (change this before deploying!)
NEXT_PUBLIC_DASHBOARD_PASSWORD=ArsenalABTest2024
